{
  "expo": {
    "name": "Garmin Insight",
    "slug": "garmin-insight",
    "scheme": "garmininsight",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.garmininsight"
    },
    "android": {
