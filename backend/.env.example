APP_NAME=Garmin Insight
ENVIRONMENT=development
DATABASE_BACKEND=sqlite
DATABASE_URL=sqlite:///./garmin_insight.db
MONGODB_URI=
MONGODB_DATABASE=garmin_insight
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081

# Keep true until you are ready to test real Garmin credentials.
DEMO_MODE=true
GARMIN_EMAIL=
GARMIN_PASSWORD=
GARMIN_MFA_CODE=
GARMIN_TOKENSTORE=.garmin_tokens

# Set this in production so cron callers must authenticate.
APP_ACCESS_TOKEN=change-me-read-token
SYNC_TOKEN=change-me

# AI provider. Default uses Gemini API; without an API key it falls back to the local grounded rule-based provider.
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional fallback provider settings when AI_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
